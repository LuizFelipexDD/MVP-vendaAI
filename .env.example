# GEMINI_API_KEY: (Opcional) Chave da API Gemini se usar diretamente no frontend.
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: URL onde o app está hospedado (para produção).
# APP_URL="https://seu-app.com"

# WEBHOOK_URL: Endpoint do Chat Trigger do n8n (usado no servidor proxy).
# Para n8n local:  http://localhost:5678/webhook/<WEBHOOK_ID>/chat
# Para n8n cloud:  https://seu-n8n.app/webhook/<WEBHOOK_ID>/chat
# O WEBHOOK_ID está no nó "Chat Trigger" do workflow.
WEBHOOK_URL="http://localhost:5678/webhook/YOUR_WEBHOOK_ID/chat"

# VITE_PROXY_API_URL: URL base do servidor proxy.
# Em dev: http://localhost:8787
VITE_PROXY_API_URL="http://localhost:8787"

# PROXY_TARGET: alvo do proxy do Vite (dev).
# PROXY_TARGET="http://localhost:8787"

# PROXY_PORT: porta do servidor proxy.
# PROXY_PORT="8787"

# PROXY_ALLOWED_ORIGIN: origem permitida para o frontend.
# PROXY_ALLOWED_ORIGIN="http://localhost:3000"
